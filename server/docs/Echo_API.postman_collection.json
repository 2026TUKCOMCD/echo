            {
              "name": "Step 2: TTS 재시도 요청",
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/conversations/tts-retry",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "conversations", "tts-retry"]
                },
                "description": "음성을 다시 받아야 하는 경우"
              },
              "response": []
