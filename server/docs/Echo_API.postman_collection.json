          ],
          "description": "TTS 재시도 테스트:\n1. 대화 시작\n2. TTS 재시도 요청"
        },
        {
          "name": "시나리오 3: 에러 케이스",
          "item": [
            {
              "name": "컨텍스트 없이 메시지 전송 (에러)",
              "request": {
                "method": "POST",
                "header": [],
